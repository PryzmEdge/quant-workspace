{
  "version": 1,
  "project": "Markdown Architecture",

  "include": [
    "stages/**/*.md",
    "docs/**/*.md",
    "_config/**/*.py",
    "_config/**/*.md",
    "proof/**/*.py",
    "proof/**/*.sql",
    "CLAUDE.md",
    "README.md"
  ],

  "exclude": [
    "graphify-out/**",
    ".make/**",
    "stages/**/receipts/**",
    "**/__pycache__/**",
    "**/*.pyc"
  ],

  "output": "graphify-out",

  "frontmatter": {
    "enabled": true,
    "node_metadata_fields": [
      "status",
      "stage",
      "operator_approved",
      "risk_tier",
      "risk_check_passed",
      "fides_label",
      "sources_count"
    ],
    "edge_on_fields": [
      "stage"
    ]
  },

  "code": {
    "enabled": true,
    "link_to_docs": true,
    "languages": ["python", "sql"]
  },

  "graph": {
    "node_types": [
      {
        "name": "stage-artifact",
        "match": "stages/**/*.md",
        "color": "#4A90D9"
      },
      {
        "name": "adr",
        "match": "docs/adr/*.md",
        "color": "#E67E22"
      },
      {
        "name": "blueprint",
        "match": "docs/blueprint*.md",
        "color": "#27AE60"
      },
      {
        "name": "config",
        "match": "_config/**",
        "color": "#8E44AD"
      },
      {
        "name": "proof",
        "match": "proof/**",
        "color": "#C0392B"
      }
    ],
    "edge_types": [
      {
        "name": "stage-dependency",
        "description": "Sequential stage promotion dependency"
      },
      {
        "name": "implements",
        "description": "Code file implements ADR or blueprint rule"
      },
      {
        "name": "references",
        "description": "Document references another document"
      }
    ]
  },

  "mcp": {
    "enabled": true,
    "port": 7331,
    "tools": [
      "query_node",
      "get_neighbors",
      "find_path",
      "filter_by_metadata"
    ]
  },

  "git": {
    "hooks": {
      "post_commit": true,
      "merge_driver": true
    },
    "rebuild_on_change": true
  },

  "token_budget": {
    "max_tokens_per_query": 800,
    "truncation_strategy": "trim_body_keep_frontmatter"
  }
}
